# Files we don't want in the Docker build context.
#
# Even though the dev container bind-mounts the repo at runtime
# (so this .dockerignore doesn't affect the live working tree),
# `docker build` still reads the build context — and the context
# defaults to the entire repo. Excluding the heavy stuff keeps
# build start-up fast.

# Git internals — never useful in the container's build context.
.git
.gitignore

# The big Linux source-tree submodules. They're reservation-only
# per CLAUDE.md (the C transpiler that would consume them is
# deferred); pulling them into the build context would balloon it.
external/coreutils
external/util-linux
external/busybox

# Scratch / cache dirs.
.pytest_cache
**/__pycache__
**/*.pyc
**/*.pyo
**/.mypy_cache
**/.ruff_cache

# Editor / OS noise.
.vscode
.idea
.DS_Store
Thumbs.db

# Saved chat history — useful in the repo, useless in a container.
chats/

# Local Claude project state if someone has it.
.claude/
